#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-push checks..."

echo "=> golangci-lint"
go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.4 run ./...

echo "=> go vet"
go vet ./...

echo "=> go test"
go test ./...

echo "=> go build"
go build -o /dev/null ./cmd/ai-chat

echo "All pre-push checks passed."
