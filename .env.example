# Telegram Bot
# Get from @BotFather on Telegram. Create a bot, copy the token here.
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (numeric). Comma-separated for multiple users.
# Find yours: message @userinfobot on Telegram, or use the getUpdates API method.
TELEGRAM_ALLOWED_USERS=

# Your primary chat ID for testing (usually same as your user ID for DMs)
TELEGRAM_CHAT_ID=

# OpenRouter API key (for LLM routing in orchestrator)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# SQLite database path (default: ~/.ai-chat/state.db)
# DB_PATH=~/.ai-chat/state.db

# Log directory (default: ~/.ai-chat/logs/)
# LOG_DIR=~/.ai-chat/logs/
